# Core bridge settings
DATABASE_URL=mysql://ghost_mail_bridge:ghost_mail_bridge@mysql:3306/ghost_mail_bridge
MAILGUN_DOMAIN=example.com
PROXY_API_KEY=your-secure-api-key-here

# Required once AWS is configured
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-key
SES_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/ghost-mail-bridge-events
NEWSLETTER_SEND_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/ghost-mail-bridge-send

# Recommended if you want the /ghost/mail dashboard to use Ghost session auth
GHOST_ADMIN_URL=https://yourdomain.com

# Optional quick-start settings (safe defaults are already built in)
AWS_REGION=us-east-1
SES_CONFIGURATION_SET=ghost-mail-bridge
APP_ROLE=all

# Optional quick-start overrides
# NEWSLETTER_SEND_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/ghost-mail-bridge-send-dlq
# PORT=3003
# LOG_LEVEL=info
# SEND_CONCURRENCY=10
# SEND_BATCH_SIZE=1000
# SEND_BATCH_CONCURRENCY=2
# SUPPRESSION_RETENTION_DAYS=0
# ADMIN_BASE_PATH=/ghost/mail
# ALLOW_INSECURE_GHOST_ADMIN_URL=0

# Advanced tuning (retry/backoff, request limits, compatibility, local-dev switches):
# see .env.advanced.example
