# AWS credentials (IAM user with SES send + SQS receive permissions)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# SQS queue URL (receives SES events via SNS)
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/ghost-mail-bridge-events

# SES Configuration Set name (must match the one attached to your SES identity)
SES_CONFIGURATION_SET=ghost-mail-bridge

# API key Ghost uses for bulkEmail__mailgun__apiKey auth against this proxy
# (set this to any secure random string)
PROXY_API_KEY=your-secure-api-key-here

# Domain Ghost sends in bulkEmail__mailgun__domain (compatibility value for Mailgun API shape)
MAILGUN_DOMAIN=example.com

# Optional: port to listen on (default: 3003)
# PORT=3003

# Optional: log level (default: info, set to debug for per-recipient send logs)
# LOG_LEVEL=info

# Optional: max concurrent SES sends per batch (default: 10)
# SEND_CONCURRENCY=10

# Optional: SES retry controls for transient/throttling failures
# Retries happen per recipient with exponential backoff + jitter.
# SES_SEND_MAX_RETRIES=3
# SES_RETRY_BASE_MS=500
# SES_RETRY_MAX_MS=10000

# Optional: suppression retention in days (default: 0 = keep forever)
# SUPPRESSION_RETENTION_DAYS=0

# Optional: max accepted request size in bytes (default: 10485760 / 10MB)
# MAX_REQUEST_BYTES=10485760

# Optional: max number of multipart form fields (default: 2000)
# MAX_FORM_FIELDS=2000

# Optional: max size for each multipart field value in bytes (default: 2097152 / 2MB)
# MAX_FIELD_SIZE_BYTES=2097152

# Optional: max recipients allowed in one send request (default: 50000)
# MAX_RECIPIENTS=50000

# Optional: max number of custom h:* headers (default: 100)
# MAX_CUSTOM_HEADERS=100

# Optional: admin dashboard base path (default: /ghost/email)
# Set to /ghost/email if you want to mount there via reverse proxy.
# ADMIN_BASE_PATH=/ghost/email

# Optional local development helpers:
# - DB_PATH lets you override SQLite file location (default picks /data if writable, otherwise ./data/ses-proxy.db)
# - DISABLE_SQS_POLLER=1 disables queue polling (useful for dashboard styling work with demo data)
# DB_PATH=./data/ses-proxy.db
# DISABLE_SQS_POLLER=1

# Dashboard auth: reuse Ghost admin session cookie by verifying against Ghost Admin API
# (requires fixed Ghost URL; avoids host-header-derived verification targets)
# GHOST_ADMIN_URL=http://yourdomain.com
# GHOST_ACCEPT_VERSION=v6.0
