# Advanced configuration for troubleshooting and tuning.
# Most users should keep code defaults and leave these unset.

# Retry and backoff tuning (per recipient)
# SES_SEND_MAX_RETRIES=3
# SES_RETRY_BASE_MS=500
# SES_RETRY_MAX_MS=10000

# Queue and worker tuning
# APP_ROLE=all
# SEND_BATCH_SIZE=1000
# SEND_BATCH_CONCURRENCY=2
# SEND_WORKER_POLL_WAIT_SECONDS=20
# SEND_WORKER_POLL_BATCH_SIZE=1
# EVENT_POLL_WAIT_SECONDS=20
# EVENT_POLL_BATCH_SIZE=10
# RUNTIME_HEARTBEAT_INTERVAL_MS=15000

# Request safety limits
# MAX_REQUEST_BYTES=10485760
# MAX_FORM_FIELDS=2000
# MAX_FIELD_SIZE_BYTES=2097152
# MAX_RECIPIENTS=50000
# MAX_CUSTOM_HEADERS=100

# Ghost Admin API compatibility override
# GHOST_ACCEPT_VERSION=v6.0
# ALLOW_INSECURE_GHOST_ADMIN_URL=1

# Local development/testing switches
# DISABLE_SES_EVENT_POLLER=1
# DISABLE_NEWSLETTER_WORKER=1
# DISABLE_ADMIN_AUTH=1
